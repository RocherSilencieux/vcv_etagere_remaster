<UserControl x:Class="vcv_etagere_remaster.Front.View.Modules.DelayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="150"
             Width="160" Height="360" Margin="10"
             Background="#2e2e2e" BorderBrush="#1a1a1a" BorderThickness="2">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Module Header -->
        <Border Grid.Row="0" Background="#0d2830" CornerRadius="3" Padding="5">
            <TextBlock Text="{Binding Name}" Foreground="#80deea" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Delay Parameters -->
        <StackPanel Grid.Row="1" Margin="5,10,5,0">
            <!-- Active Toggle -->
            <CheckBox IsChecked="{Binding IsActive}" Content="ACTIVE" Foreground="White" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <!-- Preset ComboBox -->
            <TextBlock Text="PRESET / MODE" Foreground="Gray" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,2"/>
            <ComboBox ItemsSource="{Binding AvailablePresets}"
                      SelectedItem="{Binding SelectedPreset}"
                      DisplayMemberPath="Name"
                      Background="#1a1a1a"
                      Foreground="White"
                      BorderBrush="#444"
                      FontSize="10"
                      HorizontalContentAlignment="Stretch"
                      Margin="0,0,0,8">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="Black"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
            </ComboBox>

            <!-- Time Slider -->
            <TextBlock Text="TIME (MS)" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
            <Slider Minimum="10.0" Maximum="2000.0" Value="{Binding DelayTimeMs}" Orientation="Horizontal" Margin="0,2,0,8"/>

            <!-- Feedback Slider -->
            <TextBlock Text="FEEDBACK" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
            <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Feedback}" Orientation="Horizontal" Margin="0,2,0,8"/>

            <!-- Mix Slider -->
            <TextBlock Text="MIX" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
            <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Mix}" Orientation="Horizontal" Margin="0,2,0,2"/>
        </StackPanel>

        <!-- Input Ports (Stereo) -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding InputPorts}" Margin="0,5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical" Margin="5,2">
                        <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="#111" Stroke="Gray" StrokeThickness="2" Margin="0,1"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Output Ports (Stereo) -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding OutputPorts}" Margin="0,5">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Vertical" Margin="5,2">
                        <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                        <Ellipse Width="20" Height="20" Fill="#111" Stroke="White" StrokeThickness="2" Margin="0,1"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
