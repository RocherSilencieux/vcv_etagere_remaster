<UserControl x:Class="vcv_etagere_remaster.Front.View.Modules.DelayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="150"
             Width="160" Height="360"
             Background="#2e2e2e" BorderBrush="#1a1a1a" BorderThickness="2">

    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Module Header — DragHandle -->
            <Border Grid.Row="0" Background="#0d2830" CornerRadius="3" Padding="5,5,28,5"
                    Tag="DragHandle" Cursor="SizeAll">
                <TextBlock Text="{Binding Name}" Foreground="#80deea" FontWeight="Bold"
                           HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Border>

            <!-- Delay Parameters -->
            <StackPanel Grid.Row="1" Margin="5,10,5,0">


                <TextBlock Text="PRESET / MODE" Foreground="Gray" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                <ComboBox ItemsSource="{Binding AvailablePresets}"
                          SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name"
                          Background="#1a1a1a" Foreground="Black" BorderBrush="#444"
                          FontSize="10" HorizontalContentAlignment="Stretch" Margin="0,0,0,8">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <TextBlock Text="TIME (MS)" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="10.0" Maximum="2000.0" Value="{Binding DelayTimeMs}" Orientation="Horizontal" Margin="0,2,0,8"/>

                <TextBlock Text="FEEDBACK" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Feedback}" Orientation="Horizontal" Margin="0,2,0,8"/>

                <TextBlock Text="MIX" Foreground="Gray" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Mix}" Orientation="Horizontal" Margin="0,2,0,2"/>
            </StackPanel>

            <!-- Input Ports -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding InputPorts}" Margin="0,5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="5,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="Gray" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Output Ports -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding OutputPorts}" Margin="0,5">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="5,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="White" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Bouton ✕ suppression -->
        <Button Command="{Binding RemoveCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="22" Height="22" Margin="0,6,6,0"
                Cursor="Hand" ToolTip="Supprimer le module" Panel.ZIndex="10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#aa2222" CornerRadius="11" Width="22" Height="22">
                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#ff3333"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
