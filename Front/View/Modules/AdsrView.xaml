<UserControl x:Class="vcv_etagere_remaster.Front.View.Modules.AdsrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="380" d:DesignWidth="160"
             Width="160" Height="400"
             Background="#2a1f0a" BorderBrush="#1a1200" BorderThickness="2">

    <Grid>
        <!-- Contenu principal -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header — DragHandle (couleur ambre) -->
            <Border Grid.Row="0" CornerRadius="3" Padding="5,5,28,5"
                    Tag="DragHandle" Cursor="SizeAll">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3d2800" Offset="0"/>
                        <GradientStop Color="#5c3a00" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="{Binding Name}" Foreground="#ffb347" FontWeight="Bold"
                           HorizontalAlignment="Center" FontSize="13" IsHitTestVisible="False"/>
            </Border>

            <!-- Sliders A / D / S / R -->
            <StackPanel Grid.Row="1" Margin="5,10,5,0">

                <!-- ATTACK -->
                <TextBlock Text="ATTACK (s)" Foreground="#aaa" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.001" Maximum="5.0" Value="{Binding Attack}"
                        Orientation="Horizontal" Margin="0,2,0,10"
                        Foreground="#ffb347"/>

                <!-- DECAY -->
                <TextBlock Text="DECAY (s)" Foreground="#aaa" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.001" Maximum="5.0" Value="{Binding Decay}"
                        Orientation="Horizontal" Margin="0,2,0,10"
                        Foreground="#ffb347"/>

                <!-- SUSTAIN -->
                <TextBlock Text="SUSTAIN (0–1)" Foreground="#aaa" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Sustain}"
                        Orientation="Horizontal" Margin="0,2,0,10"
                        Foreground="#ffb347"/>

                <!-- RELEASE -->
                <TextBlock Text="RELEASE (s)" Foreground="#aaa" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.001" Maximum="5.0" Value="{Binding Release}"
                        Orientation="Horizontal" Margin="0,2,0,10"
                        Foreground="#ffb347"/>

                <!-- Bouton GATE manuel -->
                <Button Command="{Binding ToggleGateCommand}"
                        HorizontalAlignment="Center" Width="80" Height="28" Cursor="Hand"
                        Margin="0,4,0,0" ToolTip="Déclencher la gate manuellement">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="GateBd" CornerRadius="5" Background="#3d2800"
                                                BorderBrush="#ffb347" BorderThickness="1.5">
                                            <TextBlock x:Name="GateTxt" Text="▶ GATE"
                                                       Foreground="#ffb347" FontWeight="Bold" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsGateHeld}" Value="True">
                                                <Setter TargetName="GateBd" Property="Background" Value="#ffb347"/>
                                                <Setter TargetName="GateTxt" Property="Foreground" Value="#1a1200"/>
                                                <Setter TargetName="GateTxt" Property="Text" Value="■ GATE"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="GateBd" Property="BorderBrush" Value="#ffd080"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Input Ports -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding InputPorts}" Margin="0,6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="6,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="#ffb347" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Output Ports -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding OutputPorts}" Margin="0,2">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="6,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="White" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Bouton ✕ suppression -->
        <Button Command="{Binding RemoveCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="22" Height="22" Margin="0,6,6,0"
                Cursor="Hand" ToolTip="Supprimer le module" Panel.ZIndex="10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#aa2222" CornerRadius="11" Width="22" Height="22">
                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#ff3333"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
