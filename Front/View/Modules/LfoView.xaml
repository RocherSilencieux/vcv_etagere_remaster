<UserControl x:Class="vcv_etagere_remaster.Front.View.Modules.LfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="150"
             Width="160" Height="360"
             Background="#252c36" BorderBrush="#141921" BorderThickness="2">

    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Module Header — DragHandle (Slate Blue) -->
            <Border Grid.Row="0" Background="#3a4a5e" CornerRadius="3" Padding="5,5,28,5"
                    Tag="DragHandle" Cursor="SizeAll">
                <TextBlock Text="{Binding Name}" Foreground="#9bbdf0" FontWeight="Bold"
                           HorizontalAlignment="Center" IsHitTestVisible="False"/>
            </Border>

            <!-- LFO Parameters -->
            <StackPanel Grid.Row="1" Margin="5,15,5,0">
                <TextBlock Text="WAVEFORM" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                <ComboBox ItemsSource="{Binding AvailableWaveforms}"
                          SelectedItem="{Binding SelectedWaveform}"
                          DisplayMemberPath="Name"
                          Background="#141921" Foreground="Black" BorderBrush="#4f5d73"
                          FontSize="10" HorizontalContentAlignment="Stretch" Margin="0,0,0,12">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Foreground" Value="Black"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <TextBlock Text="FREQUENCY (HZ)" Foreground="LightGray" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.01" Maximum="50.0" Value="{Binding Frequency}" Orientation="Horizontal" Margin="0,2,0,12"/>

                <TextBlock Text="AMPLITUDE" Foreground="LightGray" FontSize="9" HorizontalAlignment="Center"/>
                <Slider Minimum="0.0" Maximum="1.0" Value="{Binding Amplitude}" Orientation="Horizontal" Margin="0,2,0,5"/>
            </StackPanel>

            <!-- Input Ports -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding InputPorts}" Margin="0,6">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="4,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="#9bbdf0" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Output Ports -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding OutputPorts}" Margin="0,4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="4,2" Background="Transparent" ToolTip="{Binding Name}">
                            <TextBlock Text="{Binding Name}" Foreground="LightGray" FontSize="8" HorizontalAlignment="Center"/>
                            <Ellipse Width="20" Height="20" Fill="#111" Stroke="White" StrokeThickness="2" Margin="0,1"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- Bouton suppression -->
        <Button Command="{Binding RemoveCommand}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Width="22" Height="22" Margin="0,6,6,0"
                Cursor="Hand" ToolTip="Supprimer le LFO" Panel.ZIndex="10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#aa2222" CornerRadius="11" Width="22" Height="22">
                        <TextBlock Text="✕" Foreground="White" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#ff3333"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
